# Copy to .env (gitignored).

JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64

AWS_PROFILE=default
AWS_REGION=us-east-1

STREAMING_LOG_LEVEL=INFO
STREAMING_LOG_FORMAT=console

# Local dev
LOCAL_DEV=true
KAFKA_BOOTSTRAP=localhost:9092
LOCAL_PG_HOST=localhost
LOCAL_PG_PORT=5432
LOCAL_PG_USER=postgres
LOCAL_PG_PASSWORD=postgres
LOCAL_PG_DATABASE=analytics
LOCAL_REDIS_HOST=localhost
LOCAL_OPENSEARCH_HOST=localhost
LOCAL_CLICKHOUSE_HOST=localhost

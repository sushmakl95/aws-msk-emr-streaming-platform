project_name = "streaming-platform"
environment  = "dev"
aws_region   = "us-east-1"
cost_center  = "data-platform"

vpc_cidr_block     = "10.60.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b", "us-east-1c"]

# MSK (dev-size)
msk_broker_count         = 3
msk_broker_instance_type = "kafka.t3.small"
msk_ebs_volume_size_gb   = 100
msk_kafka_version        = "3.6.0"

# MSK Connect
enable_debezium_pg = false
enable_s3_sink     = true

# Kinesis
kinesis_shard_count = 1

# Sinks (dev-size)
redis_node_type          = "cache.t4g.micro"
opensearch_instance_type = "t3.small.search"
opensearch_instance_count = 1
clickhouse_task_cpu      = 1024
clickhouse_task_memory   = 4096
clickhouse_desired_count = 1

# Placeholders - fill in before running
postgres_host             = "postgres-dev.xxxxxx.us-east-1.rds.amazonaws.com"
postgres_password         = "CHANGE_ME"
opensearch_password       = "Changeme123!"
clickhouse_password       = "CHANGE_ME"
databricks_workspace_url  = "https://dbc-xxxxxxxx.cloud.databricks.com"
databricks_token          = "dapi-CHANGE_ME"

alarm_email_recipients = ["data-eng-dev@example.com"]
monthly_budget_usd     = 500
log_retention_days     = 7
